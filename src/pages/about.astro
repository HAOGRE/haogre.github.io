---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { normalizeLocale } from "@/i18n/locales";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = normalizeLocale(Astro.currentLocale ?? config.site.lang);
const about =
  (locale === "en" ? await getEntry("pages", "en/about") : null) ??
  (await getEntry("pages", "about"));

if (!about) {
  throw new Error(
    "Missing content entry: `about.md` or `about.mdx` in `src/content/pages/`"
  );
}

const { Content } = await render(about);
const t = useTranslations(locale);
const pageTitle = locale === "en" ? t.nav.about : about.data.title;
---

<Layout
  title={`${pageTitle} | ${config.site.title}`}
  description={about.data.description}
  ogImage={about.data.ogImage}
  canonicalURL={about.data.canonicalURL}
>
  <Header />

  <Breadcrumb />

  <Main pageTitle={pageTitle} class="app-prose">
    <Content />
  </Main>

  <Footer />
</Layout>
